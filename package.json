{
  "name": "xeno-crm",
  "version": "1.0.0",
  "description": "AI-native D2C shopper engagement CRM",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "concurrently \"npm:build:frontend\" \"npm:build:backend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "seed:data": "cd backend && npm run seed:data",
    "type-check": "concurrently \"npm:type-check:frontend\" \"npm:type-check:backend\"",
    "lint": "concurrently \"npm:lint:frontend\" \"npm:lint:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
